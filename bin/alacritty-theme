#!/usr/bin/env bash
set -euo pipefail

THEMES_DIR="$HOME/.config/alacritty/themes/themes"
CURRENT_THEME="$HOME/.config/alacritty/current-theme.toml"

list_themes() {
    ls "$THEMES_DIR" | sed 's/\.toml$//'
}

if [[ "${1:-}" == "--list" || "${1:-}" == "-l" ]]; then
    list_themes
    exit 0
fi

if [[ $# -eq 0 ]]; then
    THEME=$(list_themes | fzf --prompt="theme: ") || exit 0
    set -- "$THEME"
fi

THEME="$1"
THEME_FILE="$THEMES_DIR/${THEME}.toml"

if [[ ! -f "$THEME_FILE" ]]; then
    echo "Theme not found: $THEME" >&2
    echo "Run 'alacritty-theme --list' to see available themes" >&2
    exit 1
fi

cp "$THEME_FILE" "$CURRENT_THEME"
touch "$HOME/.config/alacritty/alacritty.toml"
echo "Switched to: $THEME"
